{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "honowarden-website",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-06",
  "workers_dev": true,
  "observability": {
    "enabled": true,
  },
  "routes": [
    {
      "pattern": "honowarden.com/*",
      "zone_name": "honowarden.com",
    },
    {
      "pattern": "www.honowarden.com/*",
      "zone_name": "honowarden.com",
    },
  ],
}
